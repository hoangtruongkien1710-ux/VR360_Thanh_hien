	<action name="load_m" scope="local"  args="sc" >   
		if(skin_settings.loadscene_flags, flafMenu =  skin_settings.loadscene_flags;,  flafMenu = menu_sm.loadscene_flags; );
		loadscene(*sc,null,get(flafMenu),blend(0.5));  
		
		if(menu_sm.view_marker, layer[*marc].alpha = 1; ); 	 				<!-- галка просмотренной панорамы на миниатюру -->   
		temp = caller.name; 
	 
		if(menu_sm.marker_activ_scene , layer[eye_menu].parent= temp; );
