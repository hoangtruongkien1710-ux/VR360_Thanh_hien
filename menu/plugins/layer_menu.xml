	<!-- Переключение языка  lang_set(1); -->
	<action name="lang_set" > 
		layer[lang_buttom_men].html = menu_sm.lang_%1; 
		langM = 'titleG_%1';
		
		for(set(i,0), i LT layer.count, inc(i),
			if(layer[*i].txt_%1,
				if(layer[*i].icon,
					if(layer[*i].style == 'txt_line',  style_i = menu_sm.icon_style_line );
					if(layer[*i].style == 'txt_head', style_i = menu_sm.icon_style_head );
					
					icon = '[img src=[dq]menu/image/icon/' + layer[*i].icon + '[dq] style=[dq]' + style_i + '[dq]/]'; 
					layer[*i].html = icon + layer[*i].txt_%1;
					,
					layer[*i].html = layer[*i].txt_%1;
				);
			);
		); 
		
		if(curent_grup == 'gr_1',
			layer[back_txt].html = menu_sm.title_text_%1;
			,
			t_layer = layer[*curent_grup].txt_layer;	
			layer[back_txt].html = layer[*t_layer].txt_%1;
		);
	</action>
	
	

	

	
	<!-- ///////////////////////////////    slider    //////////////////////////////////////////  -->
	
	<!-- создать бегунок с задержкой динамически, иначе глюк - нижняя панель с языками уходит вниз  menu_sm.xml -->
	<!-- Бегунок перемещение мышкой-->		  
	<style 	name="beg_m"  type="container" keep="true" align="top"  width="100%" height="50" bgalpha="0"  bgcapture="true"  parent="beg_cont_menu"
				onover="tween(layer[begun_menu2].bgcolor, 0xEEEEEE, 0.1);  " 
				onout="if(!pressed, tween(layer[begun_menu2].bgcolor, 0xBBBBBB, 0.2);   ); " 
				onup="tween(layer[begun_menu2].bgcolor, 0xBBBBBB, 0.2);  "
				ondown="tween(layer[begun_menu2].bgcolor, 0xEEEEEE,0.2); copy(drag_currenty, y); copy(drag_stagey, mouse.stagey); dragging_slider_m();" />	
				
	<style 	name="beg_m2"  type="container" keep="true" align="top" width="3" height="100%" bgcolor="0xBBBBBB" bgalpha="1" alpha="1" bgroundedge="3"  parent="begun_menu" />	 
		
	<layer name="beg_cont_menu"  type="container" keep="true" align="lefttop"  edge="lefttop"  width="5" height="100%" alpha="1" y="" zorder="60" parent="level_gr_1"
			bgcolor="0x222222"  bgalpha="0.2" bg="true"  bgcapture="false"  bgroundedge="0" >  
	</layer>  
	
	<!--   вкл/выкл слайдер -->
	<events name="update_slider" keep="true"  onresize="update_slider_m();"  />
	
	<!-- Слайдер -->
 	<action name="dragging_slider_m"  > 
		scroll_cont =  'gr_' + id_cur_grp; 
		scr = layer[*scroll_cont];
		beg = layer[begun_menu];
		hcont = layer[beg_cont_menu].pixelheight;
		
		if(pressed, 
			dy = mouse.stagey - drag_stagey; 
			newy = drag_currenty + dy;
			dragy = layer[block_menu_sm].pixelheight - pixelheight;
			if(newy LT 0, newy = 0);
			if(newy GT dragy, newy = dragy);
			layer[begun_menu].y = newy;
			val = newy * propor; 
			delayedcall(0, dragging_slider_m()); 
			propor =  scr.pixelheight / hcont; 
			newy2 = - propor * newy; 
			layer[*scroll_cont].y = newy2; 	 
			, 
			tween(bgcolor, 0xBBBBBB,0.2)
		);
	</action>	 				
							
	<!-- Установить положение и высоту бегунка 1 args="scr_m" -->	
  	<action name="update_slider_m" scope="local" > 
		if(layer[begun_menu],
			level = 'level_gr_' + curent_level;
			if(layer[beg_cont_menu].parent !== level, layer[beg_cont_menu].parent = level);   
			
			scroll_cont =  'gr_' + id_cur_grp; 
			scr = layer[*scroll_cont];
			beg = layer[begun_menu];
			hcont = layer[beg_cont_menu].pixelheight;
			 
			propor = hcont /  scr.pixelheight;			 
			Hbeg = propor * hcont;
			Ybeg = propor * scr.toverflow; 
			beg.height = Hbeg; 
			clamp(beg.height, 10, *hcont);  
			beg.y =  *Ybeg;
			 
			if(propor GT 1,
				 layer[beg_cont_menu].visible = false;
				 ,
				 layer[beg_cont_menu].visible = true; 
			);
		);
    </action>
 
 











	<!-- /////////////////////////////////////////////     показать/спрятать меню   /////////////////////////////////////////////////////  -->

	<!-- Кнопка  показать/спрятать меню -->
    <layer  name="butt_m_cont" type="container" keep="true" enabled="true" visible="true" alpha="1" align="get:menu_sm.menu_align" width="37" height="30" x="10" y="10"  
		    bgcolor="get:menu_sm.title_bgcolor" bgalpha="0.5" bgcapture="true" zorder="51"  parent="" 
			bgroundedge="0 0 0 0" bgshadow="2 2 3 0 0x1D1D1D 0.0"  
			onover="set(bgcolor,get(menu_sm.title_bgcolor)); set(bgalpha,0.5);" 
			onout="set(bgcolor,get:menu_sm.title_bgcolor);  if(open_m, set(bgalpha,0));" 
			onclick="if(open_m, hide_m();,shou_m(););"  
		/>
	<!--  анимированный крестик кнопки   -->
    <style  name="butt_m"  type="container"  keep="true"  enabled="false" visible="true" alpha="1" align="center" zorder="51" parent="butt_m_cont"
				width="17"  height="2"  bgcolor="0xFFFFFF"  bgalpha="1"  bgcapture="false"  bgroundedge="2 2 2 2" bgshadow="0 0 1 0x000001 1" />
	<!-- палочки кнопки меню -->
	<layer  name="cross_1" style="butt_m" rotate="0" y="-6" width="17" />	
	<layer  name="cross_2" style="butt_m" rotate="0"   y="0"  width="17" />	
	<layer  name="cross_3" style="butt_m" rotate="0"  y="6"  width="17" />		
	
	
	<!-- спрятать меню  -->
	<action name="hide_m" > 
		contM = layer[menu_container];
		set(open_m,false);
		hideVmen = contM.width * -1 - 20; 
		tween(contM.x,get(hideVmen),0.4); <!-- закрыть меню  -->
		tween(layer[cross_1].rotate|layer[cross_1].y,0|-6,0.6,easeincubic); 
		tween(layer[cross_2].width,17,0.6,easeincubic); 
		tween(layer[cross_3].rotate|layer[cross_3].y,0|6,0.6,easeincubic); 
		tween(layer[butt_m_cont].x|layer[butt_m_cont].y|layer[butt_m_cont].bgalpha, 10|10|0.5,0.4); 
		tween(layer[cross_1].bgcolor, 0xFFFFFF); 
		tween(layer[cross_2].bgcolor, 0xFFFFFF); 
		tween(layer[cross_3].bgcolor, 0xFFFFFF);  
	</action>
	
	<!-- открыть меню  -->
	<action name="shou_m" > 
		contM = layer[menu_container];
		open_m = true;
		tween(contM.x, get(menu_sm.menu_x), 0.4);		<!-- открыть меню  -->
		tween(layer[cross_1].rotate|layer[cross_1].y,-45|0,0.7,easeinback);
		tween(layer[cross_3].rotate|layer[cross_3].y,45|0,0.7,easeinback);
		tween(layer[cross_2].width,2,0.7,easeinback);  
		but_hide = menu_sm.menu_width - 39;
		x_clos = contM.width + menu_sm.menu_x - 37;
		tween(layer[butt_m_cont].x, get(x_clos),0.4);
		tween(layer[butt_m_cont].y|layer[butt_m_cont].bgalpha,0|0,0.4); 
		tween(layer[cross_1].bgcolor, 0xFFFFFF); 
		tween(layer[cross_2].bgcolor, 0xFFFFFF); 
		tween(layer[cross_3].bgcolor, 0xFFFFFF);  
	</action>
 

	<!--  h_s_menu();  -->
	<action name="h_s_menu" > 
		switch(open_m);
		if(open_m,	
			tween(layer[menu_container].x, get(menu_sm.menu_x), 0.4);		<!-- открыть меню  -->
			,
			hideVmen = menu_sm.menu_width * -1 - 20; 
			tween(layer[menu_container].x,get(hideVmen),0.4); 			<!-- закрыть меню  -->
		);			 
	</action>


