     <plugin name="video_popup"
        url.flash="%SWFPATH%/plugins/videoplayer.swf"
        url.html5="%SWFPATH%/plugins/videoplayer.js"
        visible="false"
        keep="true"
        align="center"
        width="80%"
        height="prop"
        zorder="999"
        pausedonstart="true"
        loop="false"
        onvideoplay="pausesoundall();"  onclick="plugin[video_popup].togglepause();"
/>
<layer name="close_video"
       type="text"
       html="X"
       keep="true"
       visible="false"
       align="center"
       x="38%"
       y="-24%"
       width="40"
       height="40"
       bgcolor="0x000000"
       bgalpha="0.7"
       css="color:#FFFFFF; font-family:Arial; font-weight:bold; font-size:22px; text-align:center; line-height:40px;"
       zorder="1000"
       onclick="plugin[video_popup].stop(); set(plugin[video_popup].visible,false); set(layer[close_video].visible,false); resumesoundall();"
/>

<!-- <action name="show_video_popup">
    set(plugin[video_popup].visible, true);
    set(layer[close_video].visible, true);
    plugin[video_popup].playvideo(%1);
</action> -->
<action name="show_video_popup">
    
    set(temp_video_url, %1);
    
    txtreplace(temp_video_url, '%FIRSTXML%/', get(xml.url));
    
    set(plugin[video_popup].visible, true);
    set(layer[close_video].visible, true);
    
    plugin[video_popup].playvideo(get(temp_video_url));
</action>

<!-- Zoom vào hospot chuyển cảnh -->
<action name="slow_zoom_and_fade">
    copy(target_ath, hotspot[%2].ath);
    copy(target_atv, hotspot[%2].atv);

    tween(view.fov, 100, 1.5, easeInOutQuad);
    tween(view.hlookat, get(target_ath), 1.5, easeInOutQuad);
    tween(view.vlookat, get(target_atv), 1.5, easeInOutQuad);

    wait(1.5);

    loadscene(%1, null, MERGE, BLEND(1.0));
</action>
